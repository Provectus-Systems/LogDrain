{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{environment=~\"$environment\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{environment=~\"$environment\"}",
          "legendFormat": "max",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "redis_connected_clients{environment=~\"$environment\"}",
          "legendFormat": "clients",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Blocked Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "redis_blocked_clients{environment=~\"$environment\"}",
          "legendFormat": "blocked",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds{environment=~\"$environment\"}",
          "legendFormat": "uptime",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "fixedColor": "blue", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Memory Fragmentation Ratio",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{environment=~\"$environment\"} / redis_memory_used_rss_bytes{environment=~\"$environment\"}",
          "legendFormat": "ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.8 },
              { "color": "yellow", "value": 1.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total{environment=~\"$environment\"} / (redis_keyspace_hits_total{environment=~\"$environment\"} + redis_keyspace_misses_total{environment=~\"$environment\"})",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "title": "Evicted Keys",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 4 },
      "targets": [
        {
          "expr": "increase(redis_evicted_keys_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "evicted (5m)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Commands/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "commands/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "input",
          "refId": "A"
        },
        {
          "expr": "rate(redis_net_output_bytes_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "output",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "Bps"
        }
      }
    },
    {
      "title": "Connected Clients Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "redis_connected_clients{environment=~\"$environment\"}",
          "legendFormat": "clients",
          "refId": "A"
        },
        {
          "expr": "redis_blocked_clients{environment=~\"$environment\"}",
          "legendFormat": "blocked",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Keys by DB",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "redis_db_keys{environment=~\"$environment\"}",
          "legendFormat": "{{db}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["redis", "cache"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "query": "production,local",
        "current": { "selected": true, "text": "production", "value": "production" },
        "hide": 0,
        "label": "Environment",
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "title": "Redis Monitoring",
  "uid": "redis-monitoring"
}
