{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{environment=~\"$environment\"}",
          "legendFormat": "used",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "redis_memory_max_bytes{environment=~\"$environment\"}",
          "legendFormat": "max",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "bytes"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Redis memory consumption (used vs. max). When used approaches max, Redis starts evicting keys based on its eviction policy."
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "redis_connected_clients{environment=~\"$environment\"}",
          "legendFormat": "clients",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Current number of client connections to Redis. Sudden spikes may indicate connection leaks in application code."
    },
    {
      "title": "Blocked Clients",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "expr": "redis_blocked_clients{environment=~\"$environment\"}",
          "legendFormat": "blocked",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Clients blocked on BLPOP/BRPOP (waiting for list data). A few is normal for queue consumers; many blocked clients may indicate stuck producers."
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds{environment=~\"$environment\"}",
          "legendFormat": "uptime",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Time since the last Redis restart. Unexpected resets may indicate OOM kills or crashes."
    },
    {
      "title": "Memory Fragmentation Ratio",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes{environment=~\"$environment\"} / redis_memory_used_rss_bytes{environment=~\"$environment\"}",
          "legendFormat": "ratio",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0.8
              },
              {
                "color": "yellow",
                "value": 1.5
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Ratio of used memory to RSS memory. Values near 1.0 are ideal. Below 0.8 or above 1.5 indicates fragmentation; above 2.0 is problematic."
    },
    {
      "title": "Hit Rate",
      "type": "gauge",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 4
      },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total{environment=~\"$environment\"} / (redis_keyspace_hits_total{environment=~\"$environment\"} + redis_keyspace_misses_total{environment=~\"$environment\"})",
          "legendFormat": "hit rate",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Percentage of key lookups that found data (hits vs. misses). Low hit rates suggest the cache isn't effective \u2014 data may be expiring too quickly or not being cached."
    },
    {
      "title": "Evicted Keys",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 4
      },
      "targets": [
        {
          "expr": "increase(redis_evicted_keys_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "evicted (5m)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Keys removed by Redis to free memory (only when maxmemory is set). Non-zero values mean Redis is under memory pressure."
    },
    {
      "title": "Commands/sec",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "commands/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "ops"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Total Redis commands processed per second. Baseline for understanding load; correlate with latency if commands/sec spikes."
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "input",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(redis_net_output_bytes_total{environment=~\"$environment\"}[5m])",
          "legendFormat": "output",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "Bps"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Bytes per second flowing in and out of Redis. High output relative to input may indicate large key reads (e.g., big hash/set operations)."
    },
    {
      "title": "Connected Clients Over Time",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "redis_connected_clients{environment=~\"$environment\"}",
          "legendFormat": "clients",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "redis_blocked_clients{environment=~\"$environment\"}",
          "legendFormat": "blocked",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Historical view of connected and blocked client counts. Helps identify patterns like connection buildup during peak hours."
    },
    {
      "title": "Keys by DB",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "expr": "redis_db_keys{environment=~\"$environment\"}",
          "legendFormat": "{{db}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Number of keys in each Redis database (db0-db15). Most applications use db0; keys in other databases may indicate Celery or caching configuration."
    }
  ],
  "schemaVersion": 38,
  "tags": [
    "redis",
    "cache"
  ],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "query": "production,local",
        "current": {
          "selected": true,
          "text": "production",
          "value": "production"
        },
        "hide": 0,
        "label": "Environment",
        "multi": false,
        "includeAll": false,
        "options": [
          {
            "selected": true,
            "text": "production",
            "value": "production"
          },
          {
            "selected": false,
            "text": "local",
            "value": "local"
          }
        ]
      }
    ]
  },
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "title": "Redis Monitoring",
  "uid": "redis-monitoring"
}
