{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{environment=~\"$environment\"}",
          "legendFormat": "{{datname}} - {{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Connection Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{environment=~\"$environment\"}) / pg_settings_max_connections{environment=~\"$environment\"}",
          "legendFormat": "utilization",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.6 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Database Size",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{environment=~\"$environment\", datname!~\"template.*\"}",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Transactions/sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "commits/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "rollbacks/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "increase(pg_stat_database_deadlocks{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "deadlocks (5m)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": { "lineWidth": 2, "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{environment=~\"$environment\", datname=~\"$database\"} / (pg_stat_database_blks_hit{environment=~\"$environment\", datname=~\"$database\"} + pg_stat_database_blks_read{environment=~\"$environment\", datname=~\"$database\"})",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "title": "Rows Returned vs Fetched",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_returned{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "returned/s",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_fetched{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "fetched/s",
          "refId": "B"
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "inserted/s",
          "refId": "C"
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "updated/s",
          "refId": "D"
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "deleted/s",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "ops"
        }
      }
    },
    {
      "title": "Temp Bytes Written",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_temp_bytes{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "temp bytes/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "Bps",
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      }
    },
    {
      "title": "Conflicts & Rollbacks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "increase(pg_stat_database_conflicts{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "conflicts",
          "refId": "A"
        },
        {
          "expr": "increase(pg_stat_database_xact_rollback{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "rollbacks",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "tags": ["postgres", "database"],
  "templating": {
    "list": [
      {
        "name": "environment",
        "type": "custom",
        "query": "production,local",
        "current": { "selected": true, "text": "production", "value": "production" },
        "hide": 0,
        "label": "Environment",
        "multi": false,
        "includeAll": false,
        "options": [
          { "selected": true, "text": "production", "value": "production" },
          { "selected": false, "text": "local", "value": "local" }
        ]
      },
      {
        "name": "database",
        "type": "query",
        "query": "label_values(pg_database_size_bytes{environment=~\"$environment\", datname!~\"template.*\"}, datname)",
        "datasource": { "type": "prometheus" },
        "refresh": 2,
        "current": {},
        "hide": 0,
        "label": "Database",
        "multi": false,
        "includeAll": false
      }
    ]
  },
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "title": "PostgreSQL Monitoring",
  "uid": "postgres-monitoring"
}
