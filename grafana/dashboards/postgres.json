{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{environment=~\"$environment\"}",
          "legendFormat": "{{datname}} - {{state}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Number of PostgreSQL connections by database and state (active, idle, idle in transaction). High idle-in-transaction counts may indicate connection leaks."
    },
    {
      "title": "Connection Utilization",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{environment=~\"$environment\"}) / pg_settings_max_connections{environment=~\"$environment\"}",
          "legendFormat": "utilization",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Current connections as a percentage of max_connections. Above 60% (yellow) means the pool is getting crowded; above 85% (red) risks connection exhaustion."
    },
    {
      "title": "Database Size",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "pg_database_size_bytes{environment=~\"$environment\", datname!~\"template.*\"}",
          "legendFormat": "{{datname}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 536870912
              },
              {
                "color": "red",
                "value": 1073741824
              }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Total size of each database on disk. Monitors growth over time \u2014 unexpected jumps may indicate runaway data or missing cleanup."
    },
    {
      "title": "Transactions/sec",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "commits/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "rollbacks/s",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Committed and rolled-back transactions per second. A healthy system has high commits and near-zero rollbacks."
    },
    {
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(pg_stat_database_deadlocks{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "deadlocks (5m)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Number of deadlocks detected in 5-minute windows. Any deadlock is worth investigating as it means concurrent transactions conflicted."
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "pg_stat_database_blks_hit{environment=~\"$environment\", datname=~\"$database\"} / (pg_stat_database_blks_hit{environment=~\"$environment\", datname=~\"$database\"} + pg_stat_database_blks_read{environment=~\"$environment\", datname=~\"$database\"})",
          "legendFormat": "hit ratio",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Percentage of data reads served from shared_buffers cache vs. disk. Should be above 99% (green). Below 90% (red) means heavy disk I/O and likely needs more memory."
    },
    {
      "title": "Rows Returned vs Fetched",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 16
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_returned{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "returned/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_fetched{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "fetched/s",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_inserted{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "inserted/s",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_updated{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "updated/s",
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "rate(pg_stat_database_tup_deleted{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "deleted/s",
          "refId": "E",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "ops"
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Rate of row operations (returned, fetched, inserted, updated, deleted) per second. A large gap between returned and fetched suggests sequential scans that could benefit from indexes."
    },
    {
      "title": "Temp Bytes Written",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_temp_bytes{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "temp bytes/s",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "Bps",
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Rate of temporary file writes. High values indicate queries that spill to disk due to insufficient work_mem \u2014 consider tuning or optimizing those queries."
    },
    {
      "title": "Conflicts & Rollbacks",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "expr": "increase(pg_stat_database_conflicts{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "conflicts",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        },
        {
          "expr": "increase(pg_stat_database_xact_rollback{environment=~\"$environment\", datname=~\"$database\"}[5m])",
          "legendFormat": "rollbacks",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        }
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Replication conflicts and transaction rollbacks over time. Conflicts occur on replicas when queries conflict with WAL replay."
    }
  ],
  "schemaVersion": 38,
  "tags": [
    "postgres",
    "database"
  ],
